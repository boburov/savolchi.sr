generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  is_verifyed  Boolean       @default(false)
  channel      Channel?
  tgId         String?       @unique
  subscription Subscription?
  createdAt    DateTime      @default(now())
}

model Channel {
  id        Int       @id @default(autoincrement())
  name      String
  pfp       String?
  banner    String?
  bio       String?
  adminId   Int       @unique
  admin     Admin     @relation(fields: [adminId], references: [id])
  subjects  Subject[]
  createdAt DateTime  @default(now())
}

model Subject {
  id        Int      @id @default(autoincrement())
  name      String
  channelId Int
  channel   Channel  @relation(fields: [channelId], references: [id])
  tests     Test[]
  createdAt DateTime @default(now())
}

model Test {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  level       TestLevel  @default(EASY)
  xpReward    Int        @default(1)
  subjectId   Int
  subject     Subject    @relation(fields: [subjectId], references: [id])
  questions   Question[]
  results     Result[]
  createdAt   DateTime   @default(now())
}

model Question {
  id     Int    @id @default(autoincrement())
  text   String
  answer String
  testId Int
  test   Test   @relation(fields: [testId], references: [id])
}

model User {
  id          Int      @id @default(autoincrement())
  username    String
  email       String   @unique
  password    String
  xp          Int      @default(0)
  rank        Rank     @default(F)
  createdAt   DateTime @default(now())
  is_verifyed Boolean  @default(false)
  results     Result[]
}

model Result {
  id          Int      @id @default(autoincrement())
  userId      Int
  testId      Int
  xpEarned    Int      @default(0)
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  test        Test     @relation(fields: [testId], references: [id])
}

model Subscription {
  id           Int              @id @default(autoincrement())
  adminId      String           @unique
  type         SubscriptionType @default(MONTHLY)
  verifed      Boolean          @default(false)
  limit        Int              @default(200)
  subjectLimit Int              @default(3)
  expiresAt    DateTime
  active       Boolean          @default(true)
  admin        Admin            @relation(fields: [adminId], references: [tgId])
  
}

enum SubscriptionType {
  MONTHLY
  THREE_MONTHS
  SIX_MONTHS
  YEARLY
}

enum TestLevel {
  EASY
  MEDIUM
  HARD
  EXPERT
  LEGENDARY
}

enum Rank {
  S
  A
  B
  C
  D
  E
  F
}
