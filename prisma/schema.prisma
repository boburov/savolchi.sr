generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  school       School?
  createdAt    DateTime      @default(now())
  subscription Subscription?
}

model School {
  id        Int      @id @default(autoincrement())
  name      String
  pfp       String?
  banner    String?
  adminId   Int      @unique
  admin     Admin    @relation(fields: [adminId], references: [id])
  tests     Test[]
  createdAt DateTime @default(now())
}

model Test {
  id          Int          @id @default(autoincrement())
  name        String
  description String?
  type        TestType     @default(PRIVATE)
  password    String?
  pfp         String?
  schoolId    Int
  school      School       @relation(fields: [schoolId], references: [id])
  questions   Question[]
  createdAt   DateTime     @default(now())
  UserAccess  UserAccess[]
}

model Question {
  id        Int      @id @default(autoincrement())
  question  String
  testId    Int
  test      Test     @relation(fields: [testId], references: [id])
  options   Option[]
  correctId Int?
}

model Option {
  id         Int      @id @default(autoincrement())
  text       String
  questionId Int
  question   Question @relation(fields: [questionId], references: [id])
}

model User {
  id         Int          @id @default(autoincrement())
  username   String
  password   String
  isVerified Boolean      @default(false)
  email      String       @unique
  testAccess UserAccess[]
  createdAt  DateTime     @default(now())
}

model UserAccess {
  id        Int      @id @default(autoincrement())
  userId    Int
  testId    Int
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
  test      Test     @relation(fields: [testId], references: [id])
}

model Subscription {
  id        Int      @id @default(autoincrement())
  adminId   Int      @unique
  userLimit Int
  expiresAt DateTime
  active    Boolean  @default(true)
  admin     Admin    @relation(fields: [adminId], references: [id])
}

enum TestType {
  PUBLIC
  PRIVATE
}
