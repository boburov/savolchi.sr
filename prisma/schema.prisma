generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  isVerified   Boolean       @default(false)
  tgId         String?       @unique
  createdAt    DateTime      @default(now())
  channel      Channel?
  subscription Subscription?
}

model Channel {
  id        String    @id @default(uuid())
  name      String
  pfp       String?
  banner    String?
  bio       String?
  adminId   String    @unique
  admin     Admin     @relation(fields: [adminId], references: [id])
  subjects  Subject[]
  createdAt DateTime  @default(now())
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id])
  tests     Test[]
  createdAt DateTime @default(now())
}

model Test {
  id        String   @id @default(uuid())
  question  String
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  options   Option[]
  results   Result[]
}

model Option {
  id        String  @id @default(uuid())
  text      String
  isCorrect Boolean @default(false)
  testId    String
  test      Test    @relation(fields: [testId], references: [id])
}

model User {
  id         String   @id @default(uuid())
  username   String
  email      String   @unique
  password   String
  xp         Int      @default(0)
  rank       Rank     @default(F)
  createdAt  DateTime @default(now())
  isVerified Boolean  @default(false)
  results    Result[]
}

model Result {
  id          String   @id @default(uuid())
  userId      String
  testId      String
  xpEarned    Int      @default(0)
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  test        Test     @relation(fields: [testId], references: [id])
}

model Subscription {
  id           String           @id @default(uuid())
  adminId      String           @unique
  type         SubscriptionType @default(MONTHLY)
  verified     Boolean          @default(false)
  limit        Int              @default(200)
  subjectLimit Int              @default(3)
  expiresAt    DateTime
  active       Boolean          @default(true)
  admin        Admin            @relation(fields: [adminId], references: [tgId])
}

enum SubscriptionType {
  MONTHLY
  THREE_MONTHS
  SIX_MONTHS
  YEARLY
}

enum Rank {
  S
  A
  B
  C
  D
  E
  F
}
